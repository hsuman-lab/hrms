generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String   @id @default(uuid())
  role_name   String   @unique
  description String?
  created_at  DateTime @default(now())
  users       User[]

  @@map("roles")
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password_hash String
  role_id       String?
  role          Role?      @relation(fields: [role_id], references: [id])
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  employee      Employee?
  leave_types   LeaveType[]
  audit_logs    AuditLog[]
  courses       Course[]

  @@map("users")
}

model Department {
  id              String     @id @default(uuid())
  department_name String
  description     String?
  created_at      DateTime   @default(now())
  employees       Employee[]

  @@map("departments")
}

model Employee {
  id                String         @id @default(uuid())
  user_id           String         @unique
  user              User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  employee_code     String         @unique
  first_name        String?
  last_name         String?
  phone             String?
  whatsapp_no       String?
  department_id     String?
  department        Department?    @relation(fields: [department_id], references: [id])
  manager_id        String?
  manager           Employee?      @relation("ManagerSubordinates", fields: [manager_id], references: [id])
  subordinates      Employee[]     @relation("ManagerSubordinates")
  joining_date      DateTime?      @db.Date
  employment_status String         @default("ACTIVE")
  base_salary       Decimal?       @db.Decimal(12, 2)
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  attendance        Attendance[]
  leave_balances    LeaveBalance[]
  leave_requests    LeaveRequest[]
  leave_approvals   LeaveApproval[]
  payroll_records   PayrollRecord[]
  enrollments       CourseEnrollment[]
  salary_structure  SalaryStructure?
  reimbursements    Reimbursement[]
  reimbursement_approvals ReimbursementApproval[]

  @@map("employees")
}

// ── Indian Salary Structure ──────────────────────────────────────────────────
model SalaryStructure {
  id                  String   @id @default(uuid())
  employee_id         String   @unique
  employee            Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  // Earnings (% of CTC or fixed)
  basic_pct           Decimal  @default(40) @db.Decimal(5, 2)   // % of gross
  hra_pct             Decimal  @default(20) @db.Decimal(5, 2)   // % of gross
  da_pct              Decimal  @default(10) @db.Decimal(5, 2)   // % of gross
  special_allowance_pct Decimal @default(20) @db.Decimal(5, 2)  // % of gross
  other_allowance     Decimal  @default(0)  @db.Decimal(12, 2)  // fixed ₹
  // Deductions
  pf_employee_pct     Decimal  @default(12) @db.Decimal(5, 2)   // % of basic (employee share)
  esi_applicable      Boolean  @default(false)                   // ESI if gross <= 21000
  professional_tax    Decimal  @default(200) @db.Decimal(8, 2)  // fixed monthly ₹
  tds_monthly         Decimal  @default(0)  @db.Decimal(12, 2)  // estimated monthly TDS
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@map("salary_structures")
}

model Attendance {
  id              String    @id @default(uuid())
  employee_id     String
  employee        Employee  @relation(fields: [employee_id], references: [id])
  attendance_date DateTime  @db.Date
  clock_in        DateTime?
  clock_out       DateTime?
  status          String?
  created_at      DateTime  @default(now())

  @@unique([employee_id, attendance_date])
  @@index([employee_id, attendance_date])
  @@map("attendance")
}

model LeaveType {
  id             String         @id @default(uuid())
  leave_name     String
  description    String?
  max_days       Int?
  is_paid        Boolean        @default(true)
  carry_forward  Boolean        @default(false)
  created_by     String?
  creator        User?          @relation(fields: [created_by], references: [id])
  created_at     DateTime       @default(now())
  leave_balances LeaveBalance[]
  leave_requests LeaveRequest[]

  @@map("leave_types")
}

model LeaveBalance {
  id             String    @id @default(uuid())
  employee_id    String
  employee       Employee  @relation(fields: [employee_id], references: [id])
  leave_type_id  String
  leave_type     LeaveType @relation(fields: [leave_type_id], references: [id])
  total_days     Int?
  used_days      Int       @default(0)
  remaining_days Int?
  updated_at     DateTime  @updatedAt

  @@unique([employee_id, leave_type_id])
  @@map("leave_balances")
}

model LeaveRequest {
  id            String          @id @default(uuid())
  employee_id   String
  employee      Employee        @relation(fields: [employee_id], references: [id])
  leave_type_id String
  leave_type    LeaveType       @relation(fields: [leave_type_id], references: [id])
  start_date    DateTime        @db.Date
  end_date      DateTime        @db.Date
  total_days    Int?
  reason        String?
  status        String          @default("PENDING")
  applied_at    DateTime        @default(now())
  approvals     LeaveApproval[]

  @@index([employee_id, status])
  @@map("leave_requests")
}

model LeaveApproval {
  id               String       @id @default(uuid())
  leave_request_id String
  leave_request    LeaveRequest @relation(fields: [leave_request_id], references: [id], onDelete: Cascade)
  approver_id      String
  approver         Employee     @relation(fields: [approver_id], references: [id])
  approval_status  String?
  remarks          String?
  approved_at      DateTime?

  @@map("leave_approvals")
}

// ── Reimbursements ───────────────────────────────────────────────────────────
model Reimbursement {
  id           String                  @id @default(uuid())
  employee_id  String
  employee     Employee                @relation(fields: [employee_id], references: [id])
  category     String                  // TRAVEL | FOOD | MEDICAL | ACCOMMODATION | OTHER
  amount       Decimal                 @db.Decimal(12, 2)
  description  String
  bill_date    DateTime                @db.Date
  status       String                  @default("PENDING") // PENDING | APPROVED | REJECTED
  applied_at   DateTime                @default(now())
  approvals    ReimbursementApproval[]

  @@index([employee_id, status])
  @@map("reimbursements")
}

model ReimbursementApproval {
  id                 String        @id @default(uuid())
  reimbursement_id   String
  reimbursement      Reimbursement @relation(fields: [reimbursement_id], references: [id], onDelete: Cascade)
  approver_id        String
  approver           Employee      @relation(fields: [approver_id], references: [id])
  approval_status    String?
  remarks            String?
  approved_at        DateTime?

  @@map("reimbursement_approvals")
}

model PayrollRecord {
  id                 String   @id @default(uuid())
  employee_id        String
  employee           Employee @relation(fields: [employee_id], references: [id])
  payroll_month      Int
  payroll_year       Int
  total_working_days Int?
  present_days       Int?
  paid_leave_days    Int?
  unpaid_leave_days  Int?
  absent_days        Int?
  salary_amount      Decimal? @db.Decimal(12, 2)  // gross
  // Indian breakdown
  basic              Decimal? @db.Decimal(12, 2)
  hra                Decimal? @db.Decimal(12, 2)
  da                 Decimal? @db.Decimal(12, 2)
  special_allowance  Decimal? @db.Decimal(12, 2)
  other_allowance    Decimal? @db.Decimal(12, 2)
  pf_employee        Decimal? @db.Decimal(12, 2)
  esi_employee       Decimal? @db.Decimal(12, 2)
  professional_tax   Decimal? @db.Decimal(12, 2)
  tds                Decimal? @db.Decimal(12, 2)
  deductions         Decimal? @db.Decimal(12, 2)  // total deductions
  net_salary         Decimal? @db.Decimal(12, 2)
  generated_at       DateTime @default(now())

  @@unique([employee_id, payroll_month, payroll_year])
  @@index([payroll_year, payroll_month])
  @@map("payroll_records")
}

model Course {
  id          String             @id @default(uuid())
  title       String
  description String?
  category    String             @default("GENERAL")
  is_mandatory Boolean           @default(false)
  duration_mins Int?
  created_by  String?
  creator     User?              @relation(fields: [created_by], references: [id])
  created_at  DateTime           @default(now())
  updated_at  DateTime           @updatedAt
  enrollments CourseEnrollment[]

  @@map("courses")
}

model CourseEnrollment {
  id           String   @id @default(uuid())
  course_id    String
  course       Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)
  employee_id  String
  employee     Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  status       String   @default("NOT_STARTED")
  progress_pct Int      @default(0)
  completed_at DateTime?
  due_date     DateTime?
  assigned_at  DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([course_id, employee_id])
  @@index([employee_id, status])
  @@map("course_enrollments")
}

model AuditLog {
  id          String   @id @default(uuid())
  user_id     String?
  user        User?    @relation(fields: [user_id], references: [id])
  action      String?
  entity_type String?
  entity_id   String?
  metadata    Json?
  created_at  DateTime @default(now())

  @@index([user_id, created_at])
  @@map("audit_logs")
}
