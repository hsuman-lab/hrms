generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model Role {
  id          String   @id @default(uuid())
  role_name   String   @unique
  description String?
  created_at  DateTime @default(now())
  users       User[]

  @@map("roles")
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password_hash String
  role_id       String?
  role          Role?      @relation(fields: [role_id], references: [id])
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  employee      Employee?
  leave_types   LeaveType[]
  audit_logs    AuditLog[]
  courses       Course[]

  @@map("users")
}

model Department {
  id              String       @id @default(uuid())
  department_name String
  description     String?
  created_at      DateTime     @default(now())
  employees       Employee[]
  job_postings    JobPosting[]

  @@map("departments")
}

model Employee {
  id                String         @id @default(uuid())
  user_id           String         @unique
  user              User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  employee_code     String         @unique
  first_name        String?
  last_name         String?
  phone             String?
  whatsapp_no       String?
  department_id     String?
  department        Department?    @relation(fields: [department_id], references: [id])
  manager_id        String?
  manager           Employee?      @relation("ManagerSubordinates", fields: [manager_id], references: [id])
  subordinates      Employee[]     @relation("ManagerSubordinates")
  joining_date      DateTime?      @db.Date
  employment_status String         @default("ACTIVE")
  base_salary       Decimal?       @db.Decimal(12, 2)
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  attendance        Attendance[]
  leave_balances    LeaveBalance[]
  leave_requests    LeaveRequest[]
  leave_approvals   LeaveApproval[]
  payroll_records   PayrollRecord[]
  enrollments       CourseEnrollment[]
  salary_structure  SalaryStructure?
  reimbursements    Reimbursement[]
  reimbursement_approvals ReimbursementApproval[]
  // ESS
  addresses              EmployeeAddress[]
  bank_details           BankDetail[]
  emergency_contacts     EmergencyContact[]
  documents              EmployeeDocument[]
  // PMS
  goals                  PerformanceGoal[]
  self_assessments       SelfAssessment[]
  manager_reviews_given  ManagerReview[]  @relation("ReviewerReviews")
  manager_reviews_received ManagerReview[] @relation("RevieweeReviews")
  feedback_given         Feedback360[]    @relation("FeedbackGiver")
  feedback_received      Feedback360[]    @relation("FeedbackReceiver")
  skills                 EmployeeSkill[]
  skill_plans            SkillDevelopmentPlan[]
  // Learning
  certificates           Certificate[]
  // Org
  job_applications       JobApplication[]
  // Onboarding
  onboarding_tasks       OnboardingChecklist[]
  policy_acknowledgements PolicyAcknowledgement[]
  onboarding_experience  OnboardingExperience?
  // Offboarding
  resignation            Resignation?
  resignation_approvals  ResignationApproval[]
  exit_interview         ExitInterview?
  fnf_settlement         FnFSettlement?
  offboarding_tasks      OffboardingChecklist[]

  @@map("employees")
}

// ── Indian Salary Structure ──────────────────────────────────────────────────
model SalaryStructure {
  id                  String   @id @default(uuid())
  employee_id         String   @unique
  employee            Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  // Earnings (% of CTC or fixed)
  basic_pct           Decimal  @default(40) @db.Decimal(5, 2)   // % of gross
  hra_pct             Decimal  @default(20) @db.Decimal(5, 2)   // % of gross
  da_pct              Decimal  @default(10) @db.Decimal(5, 2)   // % of gross
  special_allowance_pct Decimal @default(20) @db.Decimal(5, 2)  // % of gross
  other_allowance     Decimal  @default(0)  @db.Decimal(12, 2)  // fixed ₹
  // Deductions
  pf_employee_pct     Decimal  @default(12) @db.Decimal(5, 2)   // % of basic (employee share)
  esi_applicable      Boolean  @default(false)                   // ESI if gross <= 21000
  professional_tax    Decimal  @default(200) @db.Decimal(8, 2)  // fixed monthly ₹
  tds_monthly         Decimal  @default(0)  @db.Decimal(12, 2)  // estimated monthly TDS
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  @@map("salary_structures")
}

model Attendance {
  id              String    @id @default(uuid())
  employee_id     String
  employee        Employee  @relation(fields: [employee_id], references: [id])
  attendance_date DateTime  @db.Date
  clock_in        DateTime?
  clock_out       DateTime?
  status          String?
  created_at      DateTime  @default(now())

  @@unique([employee_id, attendance_date])
  @@index([employee_id, attendance_date])
  @@map("attendance")
}

model LeaveType {
  id             String         @id @default(uuid())
  leave_name     String
  description    String?
  max_days       Int?
  is_paid        Boolean        @default(true)
  carry_forward  Boolean        @default(false)
  created_by     String?
  creator        User?          @relation(fields: [created_by], references: [id])
  created_at     DateTime       @default(now())
  leave_balances LeaveBalance[]
  leave_requests LeaveRequest[]

  @@map("leave_types")
}

model LeaveBalance {
  id             String    @id @default(uuid())
  employee_id    String
  employee       Employee  @relation(fields: [employee_id], references: [id])
  leave_type_id  String
  leave_type     LeaveType @relation(fields: [leave_type_id], references: [id])
  total_days     Int?
  used_days      Int       @default(0)
  remaining_days Int?
  updated_at     DateTime  @updatedAt

  @@unique([employee_id, leave_type_id])
  @@map("leave_balances")
}

model LeaveRequest {
  id            String          @id @default(uuid())
  employee_id   String
  employee      Employee        @relation(fields: [employee_id], references: [id])
  leave_type_id String
  leave_type    LeaveType       @relation(fields: [leave_type_id], references: [id])
  start_date    DateTime        @db.Date
  end_date      DateTime        @db.Date
  total_days    Int?
  reason        String?
  status        String          @default("PENDING")
  applied_at    DateTime        @default(now())
  approvals     LeaveApproval[]

  @@index([employee_id, status])
  @@map("leave_requests")
}

model LeaveApproval {
  id               String       @id @default(uuid())
  leave_request_id String
  leave_request    LeaveRequest @relation(fields: [leave_request_id], references: [id], onDelete: Cascade)
  approver_id      String
  approver         Employee     @relation(fields: [approver_id], references: [id])
  approval_status  String?
  remarks          String?
  approved_at      DateTime?

  @@map("leave_approvals")
}

// ── Reimbursements ───────────────────────────────────────────────────────────
model Reimbursement {
  id           String                  @id @default(uuid())
  employee_id  String
  employee     Employee                @relation(fields: [employee_id], references: [id])
  category     String                  // TRAVEL | FOOD | MEDICAL | ACCOMMODATION | OTHER
  amount       Decimal                 @db.Decimal(12, 2)
  description  String
  bill_date    DateTime                @db.Date
  status       String                  @default("PENDING") // PENDING | APPROVED | REJECTED
  applied_at   DateTime                @default(now())
  approvals    ReimbursementApproval[]

  @@index([employee_id, status])
  @@map("reimbursements")
}

model ReimbursementApproval {
  id                 String        @id @default(uuid())
  reimbursement_id   String
  reimbursement      Reimbursement @relation(fields: [reimbursement_id], references: [id], onDelete: Cascade)
  approver_id        String
  approver           Employee      @relation(fields: [approver_id], references: [id])
  approval_status    String?
  remarks            String?
  approved_at        DateTime?

  @@map("reimbursement_approvals")
}

model PayrollRecord {
  id                 String   @id @default(uuid())
  employee_id        String
  employee           Employee @relation(fields: [employee_id], references: [id])
  payroll_month      Int
  payroll_year       Int
  total_working_days Int?
  present_days       Int?
  paid_leave_days    Int?
  unpaid_leave_days  Int?
  absent_days        Int?
  salary_amount      Decimal? @db.Decimal(12, 2)  // gross
  // Indian breakdown
  basic              Decimal? @db.Decimal(12, 2)
  hra                Decimal? @db.Decimal(12, 2)
  da                 Decimal? @db.Decimal(12, 2)
  special_allowance  Decimal? @db.Decimal(12, 2)
  other_allowance    Decimal? @db.Decimal(12, 2)
  pf_employee        Decimal? @db.Decimal(12, 2)
  esi_employee       Decimal? @db.Decimal(12, 2)
  professional_tax   Decimal? @db.Decimal(12, 2)
  tds                Decimal? @db.Decimal(12, 2)
  deductions         Decimal? @db.Decimal(12, 2)  // total deductions
  net_salary         Decimal? @db.Decimal(12, 2)
  generated_at       DateTime @default(now())

  @@unique([employee_id, payroll_month, payroll_year])
  @@index([payroll_year, payroll_month])
  @@map("payroll_records")
}

model Course {
  id          String             @id @default(uuid())
  title       String
  description String?
  category    String             @default("GENERAL")
  is_mandatory Boolean           @default(false)
  duration_mins Int?
  created_by  String?
  creator     User?              @relation(fields: [created_by], references: [id])
  created_at  DateTime           @default(now())
  updated_at  DateTime           @updatedAt
  enrollments CourseEnrollment[]

  @@map("courses")
}

model CourseEnrollment {
  id           String   @id @default(uuid())
  course_id    String
  course       Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)
  employee_id  String
  employee     Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  status       String   @default("NOT_STARTED")
  progress_pct Int      @default(0)
  completed_at DateTime?
  due_date     DateTime?
  assigned_at  DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([course_id, employee_id])
  @@index([employee_id, status])
  @@map("course_enrollments")
}

model AuditLog {
  id          String   @id @default(uuid())
  user_id     String?
  user        User?    @relation(fields: [user_id], references: [id])
  action      String?
  entity_type String?
  entity_id   String?
  metadata    Json?
  created_at  DateTime @default(now())

  @@index([user_id, created_at])
  @@map("audit_logs")
}

// ── ESS — Employee Self Service ──────────────────────────────────────────────
model EmployeeAddress {
  id           String   @id @default(uuid())
  employee_id  String
  employee     Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  address_type String   @default("CURRENT") // CURRENT | PERMANENT
  line1        String
  line2        String?
  city         String?
  state        String?
  pincode      String?
  country      String   @default("India")
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([employee_id])
  @@map("employee_addresses")
}

model BankDetail {
  id                 String   @id @default(uuid())
  employee_id        String   @unique
  employee           Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  bank_name          String
  account_number     String
  ifsc_code          String
  account_type       String   @default("SAVINGS") // SAVINGS | CURRENT
  branch             String?
  is_verified        Boolean  @default(false)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  @@map("bank_details")
}

model EmergencyContact {
  id           String   @id @default(uuid())
  employee_id  String
  employee     Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  name         String
  relationship String
  phone        String
  email        String?
  is_primary   Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@index([employee_id])
  @@map("emergency_contacts")
}

model EmployeeDocument {
  id            String   @id @default(uuid())
  employee_id   String
  employee      Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  doc_type      String   // AADHAAR | PAN | PASSPORT | OFFER_LETTER | CERTIFICATE | OTHER
  doc_name      String
  file_url      String
  file_size     Int?
  uploaded_at   DateTime @default(now())
  expires_at    DateTime?
  is_verified   Boolean  @default(false)

  @@index([employee_id, doc_type])
  @@map("employee_documents")
}

// ── PMS — Performance Management ─────────────────────────────────────────────
model PerformanceGoal {
  id             String    @id @default(uuid())
  employee_id    String
  employee       Employee  @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  title          String
  description    String?
  goal_type      String    @default("INDIVIDUAL") // INDIVIDUAL | TEAM | DEPARTMENTAL
  metric_type    String    @default("OKR")        // OKR | KPI | SMART
  target_value   String?
  achieved_value String?
  weightage      Decimal?  @db.Decimal(5, 2)
  due_date       DateTime? @db.Date
  review_period  String?   // e.g. "Q1-FY2026"
  status         String    @default("ACTIVE")     // ACTIVE | COMPLETED | CANCELLED
  progress_pct   Int       @default(0)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@index([employee_id, status])
  @@map("performance_goals")
}

model SelfAssessment {
  id              String   @id @default(uuid())
  employee_id     String
  employee        Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  review_period   String
  strengths       String?
  improvements    String?
  achievements    String?
  rating_self     Decimal? @db.Decimal(3, 1)
  overall_comment String?
  submitted_at    DateTime?
  status          String   @default("DRAFT") // DRAFT | SUBMITTED
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  manager_review  ManagerReview?

  @@unique([employee_id, review_period])
  @@map("self_assessments")
}

model ManagerReview {
  id                  String         @id @default(uuid())
  self_assessment_id  String         @unique
  self_assessment     SelfAssessment @relation(fields: [self_assessment_id], references: [id], onDelete: Cascade)
  reviewee_id         String
  reviewee            Employee       @relation("RevieweeReviews", fields: [reviewee_id], references: [id])
  reviewer_id         String
  reviewer            Employee       @relation("ReviewerReviews", fields: [reviewer_id], references: [id])
  review_period       String
  rating_manager      Decimal?       @db.Decimal(3, 1)
  strengths           String?
  improvements        String?
  overall_comment     String?
  final_rating        Decimal?       @db.Decimal(3, 1)
  status              String         @default("PENDING") // PENDING | IN_REVIEW | COMPLETED
  reviewed_at         DateTime?
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt

  @@index([reviewee_id, review_period])
  @@map("manager_reviews")
}

model Feedback360 {
  id              String   @id @default(uuid())
  giver_id        String
  giver           Employee @relation("FeedbackGiver", fields: [giver_id], references: [id])
  receiver_id     String
  receiver        Employee @relation("FeedbackReceiver", fields: [receiver_id], references: [id])
  review_period   String
  relationship    String   // PEER | MANAGER | SUBORDINATE | SELF
  strengths       String?
  improvements    String?
  rating          Decimal? @db.Decimal(3, 1)
  is_anonymous    Boolean  @default(true)
  submitted_at    DateTime?
  created_at      DateTime @default(now())

  @@index([receiver_id, review_period])
  @@map("feedback_360")
}

model EmployeeSkill {
  id           String   @id @default(uuid())
  employee_id  String
  employee     Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  skill_name   String
  category     String   @default("TECHNICAL") // TECHNICAL | SOFT | LEADERSHIP | DOMAIN
  proficiency  String   @default("BEGINNER")  // BEGINNER | INTERMEDIATE | ADVANCED | EXPERT
  endorsed_by  String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@unique([employee_id, skill_name])
  @@map("employee_skills")
}

model SkillDevelopmentPlan {
  id           String    @id @default(uuid())
  employee_id  String
  employee     Employee  @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  skill_name   String
  current_level String?
  target_level  String?
  action_items  String?
  resources     String?
  target_date   DateTime? @db.Date
  status        String    @default("IN_PROGRESS") // IN_PROGRESS | COMPLETED | ON_HOLD
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  @@index([employee_id, status])
  @@map("skill_development_plans")
}

// ── Learning — Certificates ───────────────────────────────────────────────────
model Certificate {
  id             String    @id @default(uuid())
  employee_id    String
  employee       Employee  @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  cert_name      String
  issuing_body   String?
  issue_date     DateTime  @db.Date
  expiry_date    DateTime? @db.Date
  credential_id  String?
  file_url       String?
  is_verified    Boolean   @default(false)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@index([employee_id])
  @@map("certificates")
}

// ── Org — Job Postings ────────────────────────────────────────────────────────
model JobPosting {
  id              String           @id @default(uuid())
  title           String
  department_id   String?
  department      Department?      @relation(fields: [department_id], references: [id])
  description     String?
  requirements    String?
  location        String?
  employment_type String           @default("FULL_TIME") // FULL_TIME | PART_TIME | CONTRACT
  is_internal     Boolean          @default(true)
  status          String           @default("OPEN")      // OPEN | CLOSED | ON_HOLD
  posted_by       String?
  salary_range    String?
  closing_date    DateTime?        @db.Date
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt
  applications    JobApplication[]

  @@index([status, is_internal])
  @@map("job_postings")
}

model JobApplication {
  id            String     @id @default(uuid())
  job_posting_id String
  job_posting   JobPosting @relation(fields: [job_posting_id], references: [id], onDelete: Cascade)
  employee_id   String
  employee      Employee   @relation(fields: [employee_id], references: [id])
  cover_note    String?
  status        String     @default("APPLIED") // APPLIED | SHORTLISTED | REJECTED | HIRED
  applied_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  @@unique([job_posting_id, employee_id])
  @@index([employee_id, status])
  @@map("job_applications")
}

// ── Onboarding ───────────────────────────────────────────────────────────────
model OnboardingTask {
  id           String                @id @default(uuid())
  task_title   String
  description  String?
  category     String                @default("GENERAL") // GENERAL | DOCUMENT | IT | HR | POLICY
  is_mandatory Boolean               @default(true)
  due_days     Int?                  // days from joining_date
  created_at   DateTime              @default(now())
  checklists   OnboardingChecklist[]

  @@map("onboarding_tasks")
}

model OnboardingChecklist {
  id               String         @id @default(uuid())
  employee_id      String
  employee         Employee       @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  task_id          String
  task             OnboardingTask @relation(fields: [task_id], references: [id])
  status           String         @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED
  completed_at     DateTime?
  remarks          String?

  @@unique([employee_id, task_id])
  @@index([employee_id, status])
  @@map("onboarding_checklists")
}

model PolicyAcknowledgement {
  id              String   @id @default(uuid())
  employee_id     String
  employee        Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  policy_name     String
  policy_version  String   @default("1.0")
  acknowledged_at DateTime @default(now())
  ip_address      String?

  @@unique([employee_id, policy_name, policy_version])
  @@index([employee_id])
  @@map("policy_acknowledgements")
}

model OnboardingExperience {
  id              String   @id @default(uuid())
  employee_id     String   @unique
  employee        Employee @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  overall_rating  Int?     // 1-5
  buddy_rating    Int?
  process_rating  Int?
  feedback        String?
  submitted_at    DateTime?
  created_at      DateTime @default(now())

  @@map("onboarding_experience")
}

// ── Offboarding ──────────────────────────────────────────────────────────────
model Resignation {
  id                String              @id @default(uuid())
  employee_id       String              @unique
  employee          Employee            @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  resignation_date  DateTime            @db.Date
  last_working_date DateTime?           @db.Date
  reason            String?
  notice_period_days Int?
  status            String              @default("PENDING") // PENDING | APPROVED | REJECTED | WITHDRAWN
  submitted_at      DateTime            @default(now())
  updated_at        DateTime            @updatedAt
  approvals         ResignationApproval[]
  exit_interview    ExitInterview?
  fnf_settlement    FnFSettlement?

  @@map("resignations")
}

model ResignationApproval {
  id             String      @id @default(uuid())
  resignation_id String
  resignation    Resignation @relation(fields: [resignation_id], references: [id], onDelete: Cascade)
  approver_id    String
  approver       Employee    @relation(fields: [approver_id], references: [id])
  status         String?     // PENDING | APPROVED | REJECTED
  remarks        String?
  approved_at    DateTime?

  @@map("resignation_approvals")
}

model ExitInterview {
  id              String      @id @default(uuid())
  employee_id     String      @unique
  employee        Employee    @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  resignation_id  String      @unique
  resignation     Resignation @relation(fields: [resignation_id], references: [id], onDelete: Cascade)
  reason_leaving  String?
  job_satisfaction Int?       // 1-5
  manager_rating  Int?
  culture_rating  Int?
  rehire_eligible Boolean     @default(true)
  suggestions     String?
  conducted_by    String?
  conducted_at    DateTime?
  created_at      DateTime    @default(now())

  @@map("exit_interviews")
}

model FnFSettlement {
  id               String      @id @default(uuid())
  employee_id      String      @unique
  employee         Employee    @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  resignation_id   String      @unique
  resignation      Resignation @relation(fields: [resignation_id], references: [id], onDelete: Cascade)
  gratuity         Decimal?    @db.Decimal(12, 2)
  leave_encashment Decimal?    @db.Decimal(12, 2)
  bonus            Decimal?    @db.Decimal(12, 2)
  deductions       Decimal?    @db.Decimal(12, 2)
  net_payable      Decimal?    @db.Decimal(12, 2)
  payment_date     DateTime?   @db.Date
  status           String      @default("PENDING") // PENDING | PROCESSED | PAID
  remarks          String?
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt

  @@map("fnf_settlements")
}

model OffboardingTask {
  id           String                 @id @default(uuid())
  task_title   String
  description  String?
  category     String                 @default("GENERAL") // GENERAL | IT | FINANCE | HR | ADMIN
  is_mandatory Boolean                @default(true)
  created_at   DateTime               @default(now())
  checklists   OffboardingChecklist[]

  @@map("offboarding_tasks")
}

model OffboardingChecklist {
  id           String          @id @default(uuid())
  employee_id  String
  employee     Employee        @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  task_id      String
  task         OffboardingTask @relation(fields: [task_id], references: [id])
  status       String          @default("PENDING") // PENDING | COMPLETED
  completed_at DateTime?
  remarks      String?

  @@unique([employee_id, task_id])
  @@index([employee_id, status])
  @@map("offboarding_checklists")
}

