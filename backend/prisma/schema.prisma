generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id          String   @id @default(uuid())
  role_name   String   @unique
  description String?
  created_at  DateTime @default(now())
  users       User[]

  @@map("roles")
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password_hash String
  role_id       String?
  role          Role?      @relation(fields: [role_id], references: [id])
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  employee      Employee?
  leave_types   LeaveType[]
  audit_logs    AuditLog[]

  @@map("users")
}

model Department {
  id              String     @id @default(uuid())
  department_name String
  description     String?
  created_at      DateTime   @default(now())
  employees       Employee[]

  @@map("departments")
}

model Employee {
  id                String         @id @default(uuid())
  user_id           String         @unique
  user              User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  employee_code     String         @unique
  first_name        String?
  last_name         String?
  phone             String?
  department_id     String?
  department        Department?    @relation(fields: [department_id], references: [id])
  manager_id        String?
  manager           Employee?      @relation("ManagerSubordinates", fields: [manager_id], references: [id])
  subordinates      Employee[]     @relation("ManagerSubordinates")
  joining_date      DateTime?      @db.Date
  employment_status String         @default("ACTIVE")
  base_salary       Decimal?       @db.Decimal(12, 2)
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt
  attendance        Attendance[]
  leave_balances    LeaveBalance[]
  leave_requests    LeaveRequest[]
  leave_approvals   LeaveApproval[]
  payroll_records   PayrollRecord[]

  @@map("employees")
}

model Attendance {
  id              String    @id @default(uuid())
  employee_id     String
  employee        Employee  @relation(fields: [employee_id], references: [id])
  attendance_date DateTime  @db.Date
  clock_in        DateTime?
  clock_out       DateTime?
  status          String?
  created_at      DateTime  @default(now())

  @@unique([employee_id, attendance_date])
  @@index([employee_id, attendance_date])
  @@map("attendance")
}

model LeaveType {
  id             String         @id @default(uuid())
  leave_name     String
  description    String?
  max_days       Int?
  is_paid        Boolean        @default(true)
  carry_forward  Boolean        @default(false)
  created_by     String?
  creator        User?          @relation(fields: [created_by], references: [id])
  created_at     DateTime       @default(now())
  leave_balances LeaveBalance[]
  leave_requests LeaveRequest[]

  @@map("leave_types")
}

model LeaveBalance {
  id             String    @id @default(uuid())
  employee_id    String
  employee       Employee  @relation(fields: [employee_id], references: [id])
  leave_type_id  String
  leave_type     LeaveType @relation(fields: [leave_type_id], references: [id])
  total_days     Int?
  used_days      Int       @default(0)
  remaining_days Int?
  updated_at     DateTime  @updatedAt

  @@unique([employee_id, leave_type_id])
  @@map("leave_balances")
}

model LeaveRequest {
  id            String          @id @default(uuid())
  employee_id   String
  employee      Employee        @relation(fields: [employee_id], references: [id])
  leave_type_id String
  leave_type    LeaveType       @relation(fields: [leave_type_id], references: [id])
  start_date    DateTime        @db.Date
  end_date      DateTime        @db.Date
  total_days    Int?
  reason        String?
  status        String          @default("PENDING")
  applied_at    DateTime        @default(now())
  approvals     LeaveApproval[]

  @@index([employee_id, status])
  @@map("leave_requests")
}

model LeaveApproval {
  id               String       @id @default(uuid())
  leave_request_id String
  leave_request    LeaveRequest @relation(fields: [leave_request_id], references: [id], onDelete: Cascade)
  approver_id      String
  approver         Employee     @relation(fields: [approver_id], references: [id])
  approval_status  String?
  remarks          String?
  approved_at      DateTime?

  @@map("leave_approvals")
}

model PayrollRecord {
  id                 String   @id @default(uuid())
  employee_id        String
  employee           Employee @relation(fields: [employee_id], references: [id])
  payroll_month      Int
  payroll_year       Int
  total_working_days Int?
  present_days       Int?
  paid_leave_days    Int?
  unpaid_leave_days  Int?
  absent_days        Int?
  salary_amount      Decimal? @db.Decimal(12, 2)
  deductions         Decimal? @db.Decimal(12, 2)
  net_salary         Decimal? @db.Decimal(12, 2)
  generated_at       DateTime @default(now())

  @@unique([employee_id, payroll_month, payroll_year])
  @@index([payroll_year, payroll_month])
  @@map("payroll_records")
}

model AuditLog {
  id          String   @id @default(uuid())
  user_id     String?
  user        User?    @relation(fields: [user_id], references: [id])
  action      String?
  entity_type String?
  entity_id   String?
  metadata    Json?
  created_at  DateTime @default(now())

  @@index([user_id, created_at])
  @@map("audit_logs")
}
